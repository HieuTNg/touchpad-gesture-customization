{
    "name": "touchpad-gesture-customization",
    "version": "3.0.0",
    "description": "Enable touchpad gestures customization in GNOME using Wayland",
    "type": "module",
    "private": true,
    "main": "extension.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/HieuTNg/touchpad-gesture-customization"
    },
