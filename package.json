    },
    "homepage": "https://github.com/HieuTNg/touchpad-gesture-customization",
    "sideEffects": false,
    "scripts": {
        "clean-dev": "rm -rf build node_modules",
        "lint:package": "eslint build --fix",
        "format:build": "bunx prettier build --write",
        "clean": "rm -rf build && mkdir build",
        "lint:extension": "eslint extension --fix",
        "format:extension": "bunx prettier extension --write",
        "transpile": "bun run lint:extension && bun run format:extension && tsc",
        "build": "bun run clean && bun run transpile && bun run lint:package && bun run format:build",
        "pack": "bun run build && make pack",
        "update": "bun run pack && make update"
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@stylistic/eslint-plugin": "^4.0.0",
